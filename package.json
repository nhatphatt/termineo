{
  "name": "termineo",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.termineo.app",
    "productName": "Termineo",
    "publish": {
      "provider": "github",
      "owner": "nhatphatt",
      "repo": "Termineo"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "electron/**/*",
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/app-builder-bin/**",
      "!node_modules/app-builder-lib/**",
      "!node_modules/typescript/**",
      "!node_modules/@rolldown/**",
      "!node_modules/vite/**",
      "!node_modules/@vitejs/**",
      "!node_modules/@types/**",
      "!node_modules/esbuild/**",
      "!node_modules/@esbuild/**",
      "!node_modules/sharp/**",
      "!node_modules/@img/**",
      "!node_modules/png-to-ico/**",
      "!node_modules/concurrently/**",
      "!node_modules/cross-env/**",
      "!node_modules/wait-on/**",
      "!node_modules/7zip-bin/**",
      "!node_modules/electron-winstaller/**",
      "!node_modules/dmg-builder/**",
      "!node_modules/@electron/**",
      "!node_modules/lightningcss-win32-x64-msvc/**",
      "!node_modules/postject/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Termineo"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
